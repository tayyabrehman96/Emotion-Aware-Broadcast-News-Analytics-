# Copy this file to .env and fill in your values. Do not commit .env.

# YouTube Data API v3 (codes.py, main.py — video search and download)
YOUTUBE_API_KEY=your_youtube_api_key_here

# AssemblyAI (codes.py, transcript_and_segmentation.py — transcription and IAB segmentation)
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# Google Generative AI (rephrase.py — semantic-preserving rephrasing)
GOOGLE_GENERATIVE_AI_API_KEY=your_google_generative_ai_key_here

# AI21 (semantic_segmentation.py — text splitting, if used)
AI21_API_KEY=your_ai21_api_key_here

# Optional: paths (override in main.py if needed)
# OUTPUT_EXCEL_PATH=./sheet/NewsData.xlsx
# DOWNLOADS_PATH=./downloads
